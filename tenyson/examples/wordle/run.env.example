#!/usr/bin/env bash

# Copy this file to examples/wordle/run.env, fill in the real values, and
# source it before starting or controlling a run.
#
# Do not commit your filled-in run.env.

# Required telemetry + experiment identity.
export TENYSON_EXPERIMENT_ID=wordle_research_YYYYMMDD
export TENYSON_DB_URL=postgresql+psycopg://USERNAME:PASSWORD@HOST:5432/tenyson

# Required for SFT / RL checkpoints and tracking.
export HF_TOKEN=hf_your_token_here
export WANDB_API_KEY=wandb_your_api_key_here
export TENYSON_HF_REPO_BASE=your-hf-username/wordle-lora

# Optional run behavior.
export TENYSON_ON_FAILURE=abort
export TENYSON_DISABLE_PARALLEL=true

# Optional Modal overrides.
export TENYSON_MODAL_GPU=A100
export TENYSON_MODAL_TIMEOUT=86400
# export TENYSON_MODAL_PROFILE=your-modal-profile
# export MODAL_PROFILE="$TENYSON_MODAL_PROFILE"

# Optional hosted Postgres ingress sync.
# export TENYSON_RDS_SECURITY_GROUP=sg-xxxxxxxxxxxxxxxxx
# export TENYSON_SYNC_RDS_LOCAL_IP=true
# export TENYSON_MODAL_RDS_CIDR=0.0.0.0/0
