# Copy this file to examples/wordle/.env and fill in real values.
#
# Do not commit your filled-in .env file.

# Required telemetry + experiment identity.
TENYSON_EXPERIMENT_ID=wordle_research_YYYYMMDD
TENYSON_WANDB_ENTITY=your-wandb-entity
TENYSON_WANDB_PROJECT=wordle-research
# Optional convenience alias for `tenyson ctl stop`.
# TENYSON_DB_URL=wandb://your-wandb-entity/wordle-research

# Required for SFT / RL checkpoints and tracking.
HF_TOKEN=hf_your_token_here
WANDB_API_KEY=wandb_your_api_key_here
# Must point to a namespace that this HF token can actually write to.
TENYSON_HF_REPO_BASE=your-hf-username/wordle-lora

# Preferred Modal auth for fresh checkouts. These are read locally by the Modal SDK.
MODAL_TOKEN_ID=modal_token_id_here
MODAL_TOKEN_SECRET=modal_token_secret_here

# Optional run behavior.
TENYSON_ON_FAILURE=abort
TENYSON_DISABLE_PARALLEL=true

# Optional Modal overrides.
TENYSON_MODAL_GPU=A100
TENYSON_MODAL_TIMEOUT=86400
